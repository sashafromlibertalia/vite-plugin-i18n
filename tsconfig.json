{
  "compileOnSave": true,
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "es2022",
      "dom"
    ],
    "baseUrl": "./",
    "module": "es2022",
    "outDir": "dist",
    "moduleResolution": "bundler",
    "declaration": true,
    "sourceMap": true,
    "downlevelIteration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "alwaysStrict": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*"
  ],
}
